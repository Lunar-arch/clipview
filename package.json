{
  "name": "clipview",
  "version": "0.2.1",
  "private": false,
  "description": "Playwright screenshot capture and live streaming for local and remote development workflows.",
  "keywords": [
    "screenshots",
    "playwright",
    "cli",
    "browser",
    "automation",
    "screenshot",
    "capture",
    "streaming",
    "devtools",
    "localhost",
    "web",
    "preview",
    "visual",
    "testing"
  ],
  "homepage": "https://github.com/Lunar-arch/clipview#readme",
  "bugs": {
    "url": "https://github.com/Lunar-arch/clipview/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lunar-arch/clipview.git"
  },
  "license": "MIT",
  "author": "Nathan Barcroft",
  "type": "module",
  "exports": {
    ".": "./packages/screenshot-kit/index.mjs"
  },
  "bin": {
    "clipview": "packages/screenshot-kit/cli.mjs"
  },
  "files": [
    "packages/screenshot-kit",
    "clipview.config.example.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clipview": "node packages/screenshot-kit/cli.mjs",
    "clipview:stream": "node packages/screenshot-kit/cli.mjs --stream --folderName live",
    "check": "node --check packages/screenshot-kit/index.mjs && node --check packages/screenshot-kit/cli.mjs && node --check packages/screenshot-kit/framework-detection.mjs && node --check packages/screenshot-kit/dev-output.mjs && node --check packages/screenshot-kit/onboarding.mjs && node --check packages/screenshot-kit/setup.mjs",
    "postinstall": "node packages/screenshot-kit/setup.mjs"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.17"
  }
}
